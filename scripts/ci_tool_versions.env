# Expected CI tool versions. CI fails loudly on mismatch, so version drift is
# a conscious bump here, never a silent fallback.
# SwiftLint installs from its pinned release binary (runner images drift
# between brew versions mid-fleet); the checksum pins the exact artifact.
SWIFTLINT_VERSION=0.63.3
SWIFTLINT_ZIP_SHA256=fb045e85e7cb3374f42a4840b6b85a0106302afa69035c0c6f29af4a44c810b6
XCODEGEN_VERSION=2.45.4
